{
  "name": "connect-desktop",
  "version": "0.1.1",
  "description": "Electron + React + TypeScript starter architecture",
  "author": "nightdevx",
  "repository": {
    "type": "git",
    "url": "https://github.com/nightdevx/connect-desktop.git"
  },
  "main": "dist/main/index.js",
  "private": true,
  "scripts": {
    "clean": "rimraf dist",
    "clean:release": "rimraf release",
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:dual": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron:a\" \"npm:dev:electron:b\"",
    "dev:main": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "dev:renderer": "vite",
    "dev:electron": "wait-on dist/main/index.js dist/preload/index.js tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electronmon --watch dist/main --watch dist/preload .",
    "dev:electron:a": "wait-on dist/main/index.js dist/preload/index.js tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 CT_USER_DATA_DIR=.profiles/instance-a electronmon --watch dist/main --watch dist/preload .",
    "dev:electron:b": "wait-on dist/main/index.js dist/preload/index.js tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 CT_USER_DATA_DIR=.profiles/instance-b electronmon --watch dist/main --watch dist/preload .",
    "build": "npm run clean && npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.json && node scripts/copy-streaming-proto.js",
    "build:renderer": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && npm run clean:release && electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.0",
    "@grpc/proto-loader": "^0.8.0",
    "dotenv": "^17.4.0",
    "electron-updater": "^6.3.9",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.96.1",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^39.8.7",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "eslint": "^9.12.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "livekit-client": "^2.18.0",
    "lucide-react": "^1.7.0",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.2",
    "vite": "^8.0.7",
    "wait-on": "^8.0.1",
    "zustand": "^5.0.12"
  }
}
