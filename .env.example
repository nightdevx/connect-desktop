# Preferred backend base URL used by src/main/config.ts
CT_BACKEND_URL=http://127.0.0.1:4001

# Optional legacy alias (used only if CT_BACKEND_URL is empty)
# BACKEND_URL=http://127.0.0.1:4001

# Optional runtime flags
# NODE_ENV=development

# Dev server URL is set by npm script in development, usually no need to set it manually
# VITE_DEV_SERVER_URL=http://localhost:5173
